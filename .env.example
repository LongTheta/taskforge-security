# TaskForge Security - Environment Configuration
# Copy to .env and adjust for your environment

APP_ENV=development
LOG_LEVEL=INFO

# Scan timeout in seconds (prevents runaway scans)
SCAN_TIMEOUT=120

# OSV enrichment
OSV_API_BASE=https://api.osv.dev
OSV_TIMEOUT=30

# CISA KEV catalog
KEV_CATALOG_URL=https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json
KEV_TIMEOUT=30

# API auth (production: set REQUIRE_API_KEY=true and API_KEY)
REQUIRE_API_KEY=false
API_KEY=

# Rate limiting (scan: 10/min, remediate: 5/min)
RATE_LIMIT_SCAN=10/minute

# GitHub PR automation (optional; dry-run by default)
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BASE_BRANCH=main
GITHUB_DRY_RUN=true
